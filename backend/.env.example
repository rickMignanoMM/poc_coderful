# ─────────────────────────────────────────────
#  LLM
# ─────────────────────────────────────────────

# URL base del server LLM (OpenAI-compatible /v1/chat/completions)
# llama.cpp:  http://127.0.0.1:8080
# Ollama:     http://127.0.0.1:11434
AI_BASE_URL=http://127.0.0.1:8080

# Nome o hash del modello da usare
# llama.cpp:  sha256-<hash blob ollama>
# Ollama:     gemma4:26b  |  gemma3:4b  |  ecc.
AI_MODEL=gemma4:26b

# ─────────────────────────────────────────────
#  WHISPER
# ─────────────────────────────────────────────

# Porta del server Whisper persistente (default: 8765)
# WHISPER_PORT=8765

# Modello Whisper da caricare (default: large-v3-turbo)
# WHISPER_MODEL=large-v3-turbo

# Thread CPU per CTranslate2 (default: min(cpu_count, 8))
# WHISPER_THREADS=8

# ─────────────────────────────────────────────
#  DEVICE BADGE
# ─────────────────────────────────────────────

# Nome visualizzato nel badge in basso a sinistra
DEVICE_NAME=Il mio PC

# Sottotitolo (es. CPU e modello)
DEVICE_SUBTITLE=Intel Core Ultra 7 155H · Gemma 4 26B

# Specifiche hardware mostrate nel modale del badge (JSON)
# Struttura: { "sezione": { "chiave": "valore", ... }, ... }
DEVICE_SPECS={"hardware":{"CPU":"Intel Core Ultra 7 155H","RAM":"64 GB LPDDR5X","Storage":"2 TB NVMe SSD"},"ai":{"Modello":"Gemma 4 26B-A4B (MoE)","Quantizzazione":"Q4_K_M","Runtime":"llama.cpp (CPU only)"}}

# ─────────────────────────────────────────────
#  MULTI-BACKEND (opzionale)
# ─────────────────────────────────────────────

# Altri dispositivi raggiungibili in LAN.
# Verranno mostrati nel backend switcher del badge.
# PEERS=[{"name":"Jetson Orin","url":"https://192.168.1.20:3443"}]
PEERS=[]
